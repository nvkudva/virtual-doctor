# Virtual Doctor — web app build-time env (Vite). Copy to `apps/web/.env.local` and fill in.
# Every value here is PUBLIC (shipped in the browser bundle); real secrets never live in
# VITE_* vars. RLS (§8.1) is what actually protects data, not obscurity of these keys.

# Active hospital slug for this build (MVP-0 is single-tenant per deploy). Falls back to the
# pilot tenant when unset — see apps/web/src/shell/hospital.ts.
VITE_VD_HOSPITAL_SLUG=citycare

# Supabase project origin. Local dev stack (supabase start) serves the API on 54421.
VITE_SUPABASE_URL=http://127.0.0.1:54421

# Supabase anon / publishable key. Browser-safe, RLS-gated. Get the local value with:
#   supabase status -o env
# and paste the ANON_KEY here. The placeholder below is NOT a working key.
VITE_SUPABASE_ANON_KEY=your-local-anon-key
