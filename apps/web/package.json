{
  "name": "@vd/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.worker.json --noEmit",
    "size": "size-limit"
  },
  "dependencies": {
    "@vd/api": "workspace:*",
    "@vd/core": "workspace:*",
    "@vd/platform": "workspace:*",
    "@vd/theme": "workspace:*",
    "@vd/ui": "workspace:*",
    "@vd/voice": "workspace:*",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@vd/config": "workspace:*",
    "@size-limit/file": "^11.1.6",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "size-limit": "^11.1.6",
    "typescript": "^5.9.2",
    "vite": "^7.1.5",
    "vite-plugin-pwa": "^1.0.3",
    "workbox-precaching": "^7.3.0",
    "workbox-routing": "^7.3.0"
  },
  "size-limit": [
    {
      "name": "module-patient initial JS (gzip)",
      "path": "dist/assets/module-patient-*.js",
      "limit": "150 KB",
      "gzip": true
    },
    {
      "name": "module-doctor initial JS (gzip)",
      "path": "dist/assets/module-doctor-*.js",
      "limit": "150 KB",
      "gzip": true
    }
  ]
}
